storage:
  root: MeetingSummaries

obs:
  enabled: false
  websocket_host: "localhost"
  websocket_port: 4455
  websocket_password: ""

summary:
  enabled: false
  provider: "openai"
  model: "gpt-5.4-mini"
  api_key_env: "OPENAI_API_KEY"
  env_file: ""
  timeout_seconds: 120
  max_chars_per_chunk: 20000

